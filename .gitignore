# ── Secrets ─────────────────────────────────────────────────────────
.env
.venv/

# ── Python ──────────────────────────────────────────────────────────
__pycache__/
*.pyc

# ── macOS ───────────────────────────────────────────────────────────
.DS_Store

# ── Source PDFs (huge, read-only, not tracked) ─────────────────────
*.pdf

# ── OCR-generated images (regenerable from PDFs via pdftoppm+magick) ─
*.jpeg

# ── Build output (regenerable) ─────────────────────────────────────
public/

.bg/

# ── Large media / local-only (keep subtitles, not the video) ───────
lecture-videos/*.webm

# ── Tool caches ────────────────────────────────────────────────────
.wrangler/
.playwright-mcp/
